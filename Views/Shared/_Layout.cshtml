<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ControlFinancieroProject</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ControlFinancieroProject.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
</head>
<body>
    <div class="d-flex flex-column min-vh-100">
        <header>
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
                <div class="container-fluid px-3 px-lg-5">
                    <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-piggy-bank-fill text-primary fs-4" aria-hidden="true"></i>
                        <span class="fw-bold">ControlFinanciero</span>
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                            aria-controls="mainNavbar" aria-expanded="false" aria-label="Mostrar navegación">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="mainNavbar">
                        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house-door me-1" aria-hidden="true"></i>
                                    <span class="d-none d-md-inline">Inicio</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Transaccion" asp-action="Index">
                                    <i class="bi bi-list-check me-1" aria-hidden="true"></i>
                                    <span class="d-none d-md-inline">Transacciones</span>
                                </a>
                            </li>

                            <li class="nav-item d-none d-lg-block">
                                <a class="nav-link text-dark" asp-controller="Categoria" asp-action="Index">
                                    <i class="bi bi-tags me-1" aria-hidden="true"></i> Categorías
                                </a>
                            </li>

                            <li class="nav-item dropdown d-none d-lg-block">
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="reportsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-bar-chart-line me-1" aria-hidden="true"></i> Informes
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="reportsDropdown">
                                    <li><a class="dropdown-item" href="#">Resumen mensual</a></li>
                                    <li><a class="dropdown-item" href="#">Comparativo</a></li>
                                </ul>
                            </li>
                        </ul>

                        <!-- Search: full on lg+, compact icon on sm -->
                        <form class="d-flex align-items-center me-2 d-none d-lg-flex" asp-controller="Transaccion" asp-action="Index" method="get" role="search">
                            <input class="form-control form-control-sm me-2" type="search" name="q" placeholder="Buscar transacciones..." aria-label="Buscar" />
                            <button class="btn btn-sm btn-outline-primary" type="submit" title="Buscar">
                                <i class="bi bi-search" aria-hidden="true"></i>
                            </button>
                        </form>

                        <div class="d-flex align-items-center gap-2">
                            <!-- compact create button: icon on xs, text on md+ -->
                            <a class="btn btn-sm btn-primary d-inline-flex align-items-center" asp-controller="Transaccion" asp-action="Create" title="Nueva transacción">
                                <i class="bi bi-plus-lg" aria-hidden="true"></i>
                                <span class="ms-1 d-none d-md-inline">Nueva transacción</span>
                            </a>

                            <!-- Search icon for small screens (opens search page) -->
                            <a class="btn btn-sm btn-outline-secondary d-flex d-lg-none align-items-center" asp-controller="Transaccion" asp-action="Index" title="Buscar">
                                <i class="bi bi-search" aria-hidden="true"></i>
                            </a>
                        </div>
                    </div> <!-- /.collapse -->
                </div>
            </nav>
        </header>

        <main class="flex-fill">
            <div class="container mt-3">
                @RenderBody()
            </div>
        </main>

        <!-- Mejor pie de página consistente y ligero -->
        <footer class="bg-white border-top mt-5">
            <div class="container py-4">
                <div class="row gy-3">
                    <div class="col-12 col-md-4">
                        <a class="d-flex align-items-center gap-2 text-decoration-none mb-2" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-piggy-bank-fill text-primary fs-4" aria-hidden="true"></i>
                            <span class="fw-bold text-dark">ControlFinanciero</span>
                        </a>
                        <p class="text-muted small mb-0">Una interfaz ligera para gestionar tus ingresos y gastos. Mantén tus finanzas ordenadas y visibles.</p>
                    </div>

                    <div class="col-6 col-md-2">
                        <h6 class="text-muted small mb-2">Navegación</h6>
                        <ul class="list-unstyled small mb-0">
                            <li><a class="text-decoration-none text-dark" asp-controller="Transaccion" asp-action="Index">Transacciones</a></li>
                            <li><a class="text-decoration-none text-dark" asp-controller="Categoria" asp-action="Index">Categorías</a></li>
                            <li><a class="text-decoration-none text-dark" asp-controller="Home" asp-action="Privacy">Privacidad</a></li>
                        </ul>
                    </div>

                    <div class="col-6 col-md-3">
                        <h6 class="text-muted small mb-2">Soporte</h6>
                        <ul class="list-unstyled small mb-0">
                            <li><a class="text-decoration-none text-dark" href="mailto:soporte@tudominio.local">Contacto</a></li>
                            <li><a class="text-decoration-none text-dark" href="#">FAQ</a></li>
                        </ul>
                    </div>

                    <div class="col-12 col-md-3 text-md-end">
                        <h6 class="text-muted small mb-2">Síguenos</h6>
                        <div class="d-flex justify-content-md-end gap-2">
                            <a class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center" href="#" aria-label="Twitter">
                                <i class="bi bi-twitter"></i>
                            </a>
                            <a class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center" href="#" aria-label="GitHub">
                                <i class="bi bi-github"></i>
                            </a>
                            <a class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center" href="#" aria-label="LinkedIn">
                                <i class="bi bi-linkedin"></i>
                            </a>
                        </div>

                        <div class="mt-3 small text-muted">
                            &copy; @DateTime.Now.Year ControlFinancieroProject
                        </div>
                    </div>
                </div>
            </div>
        </footer>
    </div> <!-- /.d-flex -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
