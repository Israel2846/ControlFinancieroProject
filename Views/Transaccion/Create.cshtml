@model ControlFinancieroProject.Models.TransactionFormViewModel

@{
    ViewData["Title"] = "Crear transacción";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Transacciones</a></li>
        <li class="breadcrumb-item active" aria-current="page">Crear</li>
    </ol>
</nav>

<div class="card shadow-sm">
    <div class="card-body">
        <h4 class="card-title mb-3"><i class="bi bi-journal-plus me-2" aria-hidden="true"></i>Crear transacción</h4>

        <form asp-action="Create" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert"></div>
            <partial name="_TransactionFormFields" model="Model" />
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_TransactionFormScriptsPartial" />
}
