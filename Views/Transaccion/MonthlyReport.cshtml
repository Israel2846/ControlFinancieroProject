@model ControlFinancieroProject.Models.MonthlyReportViewModel
@using System.Text.Json
@using ControlFinancieroProject.Models

@{
    ViewData["Title"] = $"Reporte mensual: {Model.Year}-{Model.Month:D2}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">@ViewData["Title"]</h1>
    <form class="d-flex" method="get" asp-action="MonthlyReport">
        <input type="number" name="year" value="@Model.Year" min="2000" class="form-control form-control-sm me-1"
            style="width:100px" />
        <input type="number" name="month" value="@Model.Month" min="1" max="12" class="form-control form-control-sm me-1"
            style="width:80px" />
        <button class="btn btn-sm btn-primary">Filtrar</button>
    </form>
</div>

<div class="row gy-3">
    <div class="col-12">
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
                    <div class="me-3">
                        <h6 class="mb-1">Resumen mensual</h6>
                        <div class="d-flex gap-3 align-items-center">
                            <div>
                                <div class="small text-muted">Ingresos</div>
                                <div class="h5 text-success mb-0">@Model.TotalIncome.ToString("N2")</div>
                            </div>
                            <div>
                                <div class="small text-muted">Gastos</div>
                                <div class="h5 text-danger mb-0">@Model.TotalExpense.ToString("N2")</div>
                            </div>
                            <div>
                                <div class="small text-muted">Saldo actual</div>
                                <div class="h5 mb-0">@Model.CurrentBalance.ToString("N2")</div>
                            </div>
                        </div>
                    </div>

                    <div class="flex-fill">
                        <div class="small text-muted mb-1">Relación ingreso / gasto</div>
                        <div class="progress" style="height:12px;">
                            @{
                                // Calcular totales y porcentajes usando decimal para evitar conversiones erróneas
                                var total = Math.Max(Model.TotalIncome + Model.TotalExpense, 1.0m);
                                var incomePctDec = (Model.TotalIncome / total) * 100m;
                                var expensePctDec = (Model.TotalExpense / total) * 100m;
                                var incomePct = (double)incomePctDec;
                                var expensePct = (double)expensePctDec;
                            }
                            <div class="progress-bar bg-success" role="progressbar" style="width:@(incomePct)%" aria-valuenow="@(incomePct)"
                                aria-valuemin="0" aria-valuemax="100"></div>
                            <div class="progress-bar bg-danger" role="progressbar" style="width:@(expensePct)%" aria-valuenow="@(expensePct)"
                                aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <div class="small text-muted mt-1">@Math.Round(incomePct,1)% ingresos • @Math.Round(expensePct,1)% gastos
                        </div>
                    </div>

                    <div class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" asp-action="MonthlyReport" asp-route-year="@Model.Year"
                            asp-route-month="@Model.Month">Refrescar</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts column -->
    <div class="col-12 col-lg-8">
        <div class="card mb-3 shadow-sm">
            <div class="card-body">
                <h6 class="card-title mb-3">Gastos por día</h6>
                <div style="max-height:320px;">
                    <canvas id="lineExpenses" style="width:100%;height:320px;"></canvas>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-12 col-md-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h6 class="card-title">Gastos por categoría</h6>
                        <div style="max-height:260px;">
                            <canvas id="pieExpenses" style="width:100%;height:260px;"></canvas>
                        </div>
                        <div class="small text-muted mt-2">Haz clic en una porción para ver las transacciones</div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h6 class="card-title">Ingresos por categoría</h6>
                        <div style="max-height:260px;">
                            <canvas id="pieIncomes" style="width:100%;height:260px;"></canvas>
                        </div>
                        <div class="small text-muted mt-2">Haz clic en una porción para ver las transacciones</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right column: doughnut + transactions -->
    <div class="col-12 col-lg-4">
        <div class="card shadow-sm mb-3">
            <div class="card-body text-center">
                <h6 class="card-title">Ingreso vs Gasto</h6>
                <div style="max-width:220px;margin:0 auto;">
                    <canvas id="doughnutNet" style="width:220px;height:220px;"></canvas>
                </div>
                <div class="mt-3 d-flex justify-content-center gap-3">
                    <span class="badge bg-success">Ingresos: @Model.TotalIncome.ToString("N2")</span>
                    <span class="badge bg-danger">Gastos: @Model.TotalExpense.ToString("N2")</span>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="card-title">Transacciones (@Model.Transacciones.Count())</h6>
                <div class="table-responsive" style="max-height:360px; overflow:auto">
                    <table class="table table-sm mb-0">
                        <thead class="small text-muted">
                            <tr>
                                <th>Fecha</th>
                                <th>Descripción</th>
                                <th class="text-end">Monto</th>
                                <th>Tipo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.Transacciones)
                            {
                                <tr>
                                    <td class="small">@t.Fecha.ToString("yyyy-MM-dd")</td>
                                    <td class="small text-truncate" style="max-width:140px">@t.Descripcion</td>
                                    <td class="text-end small">@t.Monto.ToString("N2")</td>
                                    <td>
                                        @if (t.Categoria?.Tipo == TipoCategoria.Ingreso)
                                        {
                                            <span class="badge bg-success small">Ingreso</span>
                                        }
                                        else if (t.Categoria?.Tipo == TipoCategoria.Gasto)
                                        {
                                            <span class="badge bg-danger small">Gasto</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary small">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para mostrar transacciones filtradas por categoría -->
<div class="modal fade" id="categoryTxModal" tabindex="-1" aria-labelledby="categoryTxModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="categoryTxModalLabel">Transacciones</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div id="categoryTxSummary" class="mb-2 small text-muted"></div>
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead class="small text-muted">
                            <tr><th>Fecha</th><th>Descripción</th><th class="text-end">Monto</th><th>Tipo</th></tr>
                        </thead>
                        <tbody id="categoryTxBody"></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        (function () {
            // Serializados desde servidor
            const dailyLabels = @Html.Raw(JsonSerializer.Serialize(Model.DailyLabels));
            const dailyExpenses = (@Html.Raw(JsonSerializer.Serialize(Model.DailyExpenses)) || []).map(v => Number(v) || 0);

            const expenseLabels = @Html.Raw(JsonSerializer.Serialize(Model.ExpenseCategoryLabels ?? new List<string>()));
            const expenseValues = (@Html.Raw(JsonSerializer.Serialize(Model.ExpenseCategoryValues ?? new List<decimal>()))).map(v => Number(v) || 0);

            const incomeLabels = @Html.Raw(JsonSerializer.Serialize(Model.IncomeCategoryLabels ?? new List<string>()));
            const incomeValues = (@Html.Raw(JsonSerializer.Serialize(Model.IncomeCategoryValues ?? new List<decimal>()))).map(v => Number(v) || 0);

            const totalIncome = Number(@Model.TotalIncome);
            const totalExpense = Number(@Model.TotalExpense);

            // Serializar transacciones del mes para filtrado cliente
            const transacciones = @Html.Raw(JsonSerializer.Serialize(Model.Transacciones.Select(t => new {
                Id = t.Id,
                Fecha = t.Fecha.ToString("yyyy-MM-dd"),
                Descripcion = t.Descripcion,
                Monto = t.Monto,
                Categoria = t.Categoria != null ? t.Categoria.Descripcion : null,
                Tipo = t.Categoria != null ? t.Categoria.Tipo.ToString() : null
            })));

            function fmt(v) {
                return v.toLocaleString('es-ES', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }

            // LINE - gastos por día
            const ctxLine = document.getElementById('lineExpenses').getContext('2d');
            const lineChart = new Chart(ctxLine, {
                type: 'line',
                data: {
                    labels: dailyLabels,
                    datasets: [{
                        label: 'Gasto diario',
                        data: dailyExpenses,
                        borderColor: 'rgba(220,53,69,0.95)',
                        backgroundColor: 'rgba(220,53,69,0.12)',
                        fill: true,
                        tension: 0.3,
                        pointRadius: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: { ticks: { maxRotation: 0, autoSkip: true } },
                        y: {
                            beginAtZero: true,
                            ticks: { callback: v => fmt(Number(v) || 0) }
                        }
                    },
                    plugins: {
                        legend: { display: false },
                        tooltip: { callbacks: { label: ctx => `${ctx.dataset.label}: ${fmt(ctx.parsed.y)}` } }
                    }
                }
            });

            // PIE - gastos por categoría
            const ctxPieE = document.getElementById('pieExpenses').getContext('2d');
            const pieExpensesChart = new Chart(ctxPieE, {
                type: 'pie',
                data: { labels: expenseLabels, datasets: [{ data: expenseValues, backgroundColor: generateColors(expenseValues.length) }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' }, tooltip: { callbacks: { label: (ctx) => `${ctx.label}: ${fmt(ctx.parsed)}` } } } }
            });

            // PIE - ingresos por categoría
            const ctxPieI = document.getElementById('pieIncomes').getContext('2d');
            const pieIncomesChart = new Chart(ctxPieI, {
                type: 'pie',
                data: { labels: incomeLabels, datasets: [{ data: incomeValues, backgroundColor: generateColors(incomeValues.length) }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' }, tooltip: { callbacks: { label: (ctx) => `${ctx.label}: ${fmt(ctx.parsed)}` } } } }
            });

            // DOUGHNUT - Ingreso vs Gasto
            const ctxD = document.getElementById('doughnutNet').getContext('2d');
            const doughnutChart = new Chart(ctxD, {
                type: 'doughnut',
                data: { labels: ['Ingresos', 'Gastos'], datasets: [{ data: [totalIncome, totalExpense], backgroundColor: ['#198754', '#dc3545'] }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' }, tooltip: { callbacks: { label: (ctx) => `${ctx.label}: ${fmt(ctx.parsed)}` } } } }
            });

            function generateColors(n) {
                const base = ['#0d6efd','#6610f2','#6f42c1','#d63384','#dc3545','#fd7e14','#ffc107','#198754','#20c997','#0dcaf0','#6c757d'];
                return Array.from({length: n}).map((_, i) => base[i % base.length]);
            }

            // Modal utilities
            const categoryModalEl = document.getElementById('categoryTxModal');
            const categoryModal = new bootstrap.Modal(categoryModalEl);
            const categoryTxBody = document.getElementById('categoryTxBody');
            const categoryTxTitle = document.getElementById('categoryTxModalLabel');
            const categoryTxSummary = document.getElementById('categoryTxSummary');

            function openCategoryModal(categoryLabel, typeLabel) {
                const rows = transacciones
                    .filter(t => (t.Categoria || '') === categoryLabel)
                    .sort((a,b) => b.Fecha.localeCompare(a.Fecha)); // más recientes arriba

                categoryTxTitle.textContent = `${categoryLabel} — Transacciones (${rows.length})`;
                categoryTxSummary.textContent = typeLabel ? `Tipo: ${typeLabel}` : '';

                categoryTxBody.innerHTML = rows.map(t => {
                    const tipoBadge = t.Tipo === 'Ingreso' ? '<span class="badge bg-success">Ingreso</span>' : (t.Tipo === 'Gasto' ? '<span class="badge bg-danger">Gasto</span>' : '<span class="badge bg-secondary">-</span>');
                    return `<tr>
                        <td class="small">${t.Fecha}</td>
                        <td class="small">${escapeHtml(t.Descripcion || '')}</td>
                        <td class="text-end small">${fmt(Number(t.Monto) || 0)}</td>
                        <td class="small text-end">${tipoBadge}</td>
                    </tr>`;
                }).join('');

                categoryModal.show();
            }

            // escapeHtml seguro
            function escapeHtml(str) {
                const div = document.createElement('div');
                div.appendChild(document.createTextNode(String(str)));
                return div.innerHTML;
            }

            // Attach click handlers: obtener segmento clicado y abrir modal
            document.getElementById('pieExpenses').onclick = function(evt) {
                const points = pieExpensesChart.getElementsAtEventForMode(evt, 'nearest', { intersect: true });
                if (!points.length) return;
                const idx = points[0].index;
                const label = pieExpensesChart.data.labels[idx];
                openCategoryModal(label, 'Gasto');
            };

            document.getElementById('pieIncomes').onclick = function(evt) {
                const points = pieIncomesChart.getElementsAtEventForMode(evt, 'nearest', { intersect: true });
                if (!points.length) return;
                const idx = points[0].index;
                const label = pieIncomesChart.data.labels[idx];
                openCategoryModal(label, 'Ingreso');
            };
        })();
    </script>
}