@model ControlFinancieroProject.Models.TransactionIndexViewModel
@using ControlFinancieroProject.Models

@{
    ViewData["Title"] = "Transacciones";
    var fromDateValue = Model.FromDate?.ToString("yyyy-MM-dd") ?? string.Empty;
    var toDateValue = Model.ToDate?.ToString("yyyy-MM-dd") ?? string.Empty;
    var selectedCategoryIds = new HashSet<int>(Model.SelectedCategoryIds);
    var hasActiveFilters =
        !string.IsNullOrWhiteSpace(Model.SearchTerm) ||
        Model.SelectedTipo.HasValue ||
        Model.SelectedCategoryIds.Count > 0 ||
        Model.HasDateRange;
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.bootstrap5.min.css" />
}

<section class="py-3 py-lg-4">
    <div class="container">

        @* Page header *@
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
            <div>
                <h1 class="h4 fw-bold mb-1">
                    <i class="bi bi-list-check text-primary me-2" aria-hidden="true"></i>Transacciones
                </h1>
                <p class="text-muted small mb-0">Busca y filtra tus movimientos financieros.</p>
            </div>
            <a asp-action="Create" class="btn btn-primary btn-sm d-inline-flex align-items-center gap-2 flex-shrink-0">
                <i class="bi bi-plus-lg" aria-hidden="true"></i>Nueva transacción
            </a>
        </div>

        @* Stats row *@
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="text-muted small mb-1">Resultados</div>
                    <div class="fw-bold fs-5">@Model.TransactionCount</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="text-muted small mb-1">Ingresos</div>
                    <div class="fw-bold fs-5 text-success">+@Model.FilteredIncome.ToString("N2")</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="text-muted small mb-1">Gastos</div>
                    <div class="fw-bold fs-5 text-danger">-@Model.FilteredExpense.ToString("N2")</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm text-center py-3">
                    <div class="text-muted small mb-1">Neto</div>
                    <div class="fw-bold fs-5 @(Model.FilteredNet >= 0 ? "text-primary" : "text-secondary")">
                        @(Model.FilteredNet >= 0 ? "+" : "")@Model.FilteredNet.ToString("N2")
                    </div>
                </div>
            </div>
        </div>

        @* Filter card *@
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-3 p-lg-4">
                <p class="text-muted small fw-semibold text-uppercase mb-3" style="letter-spacing:.06em;">
                    <i class="bi bi-funnel me-1" aria-hidden="true"></i>Filtros
                </p>

                <form id="transactionFiltersForm" method="get" asp-action="Index">
                    <div class="row g-3 align-items-end">

                        @* Search *@
                        <div class="col-12 col-lg-5">
                            <label for="searchTerm" class="form-label text-muted small fw-semibold mb-1">Buscar</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted">
                                    <i class="bi bi-search" aria-hidden="true"></i>
                                </span>
                                <input
                                    id="searchTerm"
                                    name="q"
                                    value="@Model.SearchTerm"
                                    class="form-control border-start-0 ps-1"
                                    placeholder="Descripción o categoría…" />
                            </div>
                        </div>

                        @* Type *@
                        <div class="col-12 col-sm-6 col-lg-2">
                            <label for="tipo" class="form-label text-muted small fw-semibold mb-1">Tipo</label>
                            <select id="tipo" name="tipo" class="form-select">
                                <option value="">Todos</option>
                                @foreach (var tipo in Enum.GetValues<TipoCategoria>())
                                {
                                    <option value="@tipo" selected="@(Model.SelectedTipo == tipo ? "selected" : null)">@tipo</option>
                                }
                            </select>
                        </div>

                        @* Date range *@
                        <div class="col-12 col-sm-6 col-lg-5">
                            <label class="form-label text-muted small fw-semibold mb-1">Rango de fechas <span class="fw-normal opacity-75">(vacío = todos)</span></label>
                            <div class="input-group">
                                <button id="prevRangeBtn" class="btn btn-outline-secondary" type="button" title="Retroceder rango">
                                    <i class="bi bi-chevron-left" aria-hidden="true"></i>
                                </button>
                                <input id="fromDate" name="fromDate" type="date" class="form-control text-center" value="@fromDateValue" />
                                <span class="input-group-text bg-light text-muted px-2">—</span>
                                <input id="toDate" name="toDate" type="date" class="form-control text-center" value="@toDateValue" />
                                <button id="nextRangeBtn" class="btn btn-outline-secondary" type="button" title="Avanzar rango">
                                    <i class="bi bi-chevron-right" aria-hidden="true"></i>
                                </button>
                            </div>
                        </div>

                        @* Categories *@
                        <div class="col-12 col-lg-8">
                            <label for="categorySelect" class="form-label text-muted small fw-semibold mb-1">Categorías <span class="fw-normal opacity-75">(vacío = todas)</span></label>
                            <select id="categorySelect" name="categoryIds" class="form-select" multiple>
                                @foreach (var categoria in Model.Categorias)
                                {
                                    var isSelected = selectedCategoryIds.Contains(categoria.Id);
                                    <option value="@categoria.Id"
                                            data-tipo="@categoria.Tipo"
                                            selected="@(isSelected ? "selected" : null)">@categoria.Descripcion (@(categoria.Tipo == TipoCategoria.Ingreso ? "Ingreso" : "Gasto"))</option>
                                }
                            </select>
                        </div>

                        @* Action buttons *@
                        <div class="col-12 col-lg-4">
                            <div class="d-flex gap-2 flex-wrap">
                                <button type="submit" class="btn btn-primary flex-fill">
                                    <i class="bi bi-funnel me-1" aria-hidden="true"></i>Buscar
                                </button>
                                <button id="todayFiltersBtn" type="button" class="btn btn-outline-secondary" title="Ver solo hoy">
                                    <i class="bi bi-calendar-check" aria-hidden="true"></i>
                                    <span class="d-none d-sm-inline ms-1">Hoy</span>
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary" title="Limpiar todos los filtros">
                                    <i class="bi bi-x-circle" aria-hidden="true"></i>
                                    <span class="d-none d-sm-inline ms-1">Limpiar</span>
                                </a>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
        </div>

        @* Active filter chips *@
        @if (!string.IsNullOrWhiteSpace(Model.FilterErrorMessage))
        {
            <div class="alert alert-warning d-flex align-items-center gap-2 shadow-sm mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill" aria-hidden="true"></i>
                @Model.FilterErrorMessage
            </div>
        }
        else if (hasActiveFilters)
        {
            <div class="d-flex flex-wrap gap-2 mb-4 align-items-center">
                <span class="text-muted small me-1">Filtros activos:</span>
                @if (Model.HasDateRange)
                {
                    <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 fw-normal">
                        <i class="bi bi-calendar3 me-1"></i>@(Model.FromDate?.ToString("dd/MM/yyyy") ?? "inicio") – @(Model.ToDate?.ToString("dd/MM/yyyy") ?? "hoy")
                    </span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                {
                    <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 fw-normal">
                        <i class="bi bi-search me-1"></i>@Model.SearchTerm
                    </span>
                }
                @if (Model.SelectedTipo.HasValue)
                {
                    <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 fw-normal">
                        <i class="bi bi-tag me-1"></i>@Model.SelectedTipo
                    </span>
                }
                @if (Model.SelectedCategoryIds.Count > 0)
                {
                    <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 fw-normal">
                        <i class="bi bi-folder me-1"></i>@Model.SelectedCategoryIds.Count categoría@(Model.SelectedCategoryIds.Count == 1 ? "" : "s")
                    </span>
                }
                <a asp-action="Index" class="btn btn-link btn-sm p-0 text-muted ms-1 text-decoration-none">
                    <i class="bi bi-x me-1"></i>Limpiar todo
                </a>
            </div>
        }

        @* Results *@
        @if (string.IsNullOrWhiteSpace(Model.FilterErrorMessage) && Model.TransactionCount == 0)
        {
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center text-muted py-5">
                    <i class="bi bi-journal-text fs-1 mb-3 d-block opacity-25" aria-hidden="true"></i>
                    <div class="fw-semibold mb-2">
                        @(hasActiveFilters ? "No hay transacciones con esos filtros." : "No hay transacciones para mostrar.")
                    </div>
                    <div class="small mb-4">
                        @(hasActiveFilters
                            ? "Prueba ajustando el rango, las palabras clave o las categorías seleccionadas."
                            : "Crea tu primera transacción para empezar a registrar movimientos.")
                    </div>
                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                        <a asp-action="Create" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-plus-lg me-1"></i>Crear transacción
                        </a>
                        @if (hasActiveFilters)
                        {
                            <a asp-action="Index" class="btn btn-link btn-sm">Restablecer filtros</a>
                        }
                    </div>
                </div>
            </div>
        }
        else if (string.IsNullOrWhiteSpace(Model.FilterErrorMessage))
        {
            <div id="transactionsGrid" class="row g-3">
                @foreach (var transaccion in Model.Transacciones)
                {
                    var desc = (transaccion.Descripcion ?? string.Empty).Trim();
                    var titleText = string.IsNullOrWhiteSpace(desc) ? "-" : (desc.Length > 80 ? desc.Substring(0, 80) + "..." : desc);
                    var showFullDesc = !string.IsNullOrWhiteSpace(desc) && desc.Length > 80;
                    var isIngreso = transaccion.Categoria?.Tipo == TipoCategoria.Ingreso;
                    var amountSign = isIngreso ? "+" : "-";
                    var amountClass = isIngreso ? "text-success" : "text-danger";
                    var badgeClass = isIngreso ? "border border-success text-success" : "border border-danger text-danger";

                    <div class="col-12 col-md-6 col-xl-4">
                        <div class="card h-100 shadow-sm border-0 hover-scale">
                            <div class="card-body d-flex flex-column">
                                <div class="d-flex align-items-start justify-content-between mb-2">
                                    <div class="me-2" style="min-width:0;">
                                        <h5 class="card-title mb-1 text-truncate">@titleText</h5>
                                        <div class="text-muted small">
                                            <i class="bi bi-calendar3 me-1" aria-hidden="true"></i>@transaccion.Fecha.ToString("dd/MM/yyyy")
                                        </div>
                                    </div>
                                    <div class="text-end ms-2 flex-shrink-0">
                                        <div class="fw-semibold fs-5 @amountClass">@amountSign@transaccion.Monto.ToString("N2")</div>
                                        @if (transaccion.Categoria != null)
                                        {
                                            <span class="badge rounded-pill @badgeClass" style="background-color:rgba(0,0,0,.03);font-size:.7rem;">
                                                <i class="bi @(isIngreso ? "bi-arrow-up-short" : "bi-arrow-down-short")" aria-hidden="true"></i>
                                                @(isIngreso ? "Ingreso" : "Gasto")
                                            </span>
                                        }
                                    </div>
                                </div>

                                @if (showFullDesc)
                                {
                                    <p class="card-text text-muted small mb-3">@desc</p>
                                }

                                <ul class="list-unstyled small text-muted mb-3">
                                    <li><i class="bi bi-folder2 me-1" aria-hidden="true"></i><strong>Categoría:</strong> @(transaccion.Categoria?.Descripcion ?? "-")</li>
                                    <li><i class="bi bi-arrow-left-circle me-1" aria-hidden="true"></i><strong>Saldo anterior:</strong> @transaccion.SaldoAnterior.ToString("N2")</li>
                                    <li><i class="bi bi-arrow-right-circle me-1" aria-hidden="true"></i><strong>Saldo nuevo:</strong> @transaccion.SaldoNuevo.ToString("N2")</li>
                                </ul>

                                <div class="mt-auto d-flex gap-2">
                                    <a asp-action="Details" asp-route-id="@transaccion.Id" class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center">
                                        <i class="bi bi-eye me-1" aria-hidden="true"></i><span class="d-none d-sm-inline">Ver</span>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@transaccion.Id" class="btn btn-sm btn-outline-warning d-inline-flex align-items-center">
                                        <i class="bi bi-pencil me-1" aria-hidden="true"></i><span class="d-none d-sm-inline">Editar</span>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@transaccion.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger d-inline-flex align-items-center"
                                                onclick="return confirm('¿Eliminar transacción?');">
                                            <i class="bi bi-trash me-1" aria-hidden="true"></i><span class="d-none d-sm-inline">Eliminar</span>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/js/tom-select.complete.min.js"></script>
    <script>
        (function () {
            // ── Tom Select: multi-select combobox for categories ──────────────────
            const catEl = document.getElementById('categorySelect');
            if (catEl) {
                new TomSelect(catEl, {
                    plugins: ['remove_button'],
                    placeholder: 'Todas las categorías',
                    maxItems: null,
                    closeAfterSelect: false,
                    render: {
                        option: function (data, escape) {
                            const tipo = data.element ? data.element.getAttribute('data-tipo') : '';
                            const isIngreso = tipo === 'Ingreso';
                            const color = isIngreso ? '#198754' : '#dc3545';
                            const icon = isIngreso ? 'bi-arrow-up-circle-fill' : 'bi-arrow-down-circle-fill';
                            return `<div style="display:flex;align-items:center;gap:.5rem;">
                                <i class="bi ${escape(icon)}" style="color:${color};font-size:.9rem;"></i>
                                <span>${escape(data.text)}</span>
                            </div>`;
                        }
                    }
                });
            }

            // ── Date range nav ────────────────────────────────────────────────────
            const form = document.getElementById('transactionFiltersForm');
            const fromDateInput = document.getElementById('fromDate');
            const toDateInput = document.getElementById('toDate');

            if (!form || !fromDateInput || !toDateInput) return;

            function formatDate(date) {
                const yyyy = date.getFullYear();
                const mm = String(date.getMonth() + 1).padStart(2, '0');
                const dd = String(date.getDate()).padStart(2, '0');
                return `${yyyy}-${mm}-${dd}`;
            }

            function parseDate(value) {
                if (!value) return null;
                const [y, m, d] = value.split('-').map(Number);
                return (isNaN(y) || isNaN(m) || isNaN(d)) ? null : new Date(y, m - 1, d);
            }

            function shiftRange(days) {
                const today = new Date();
                const from = parseDate(fromDateInput.value) ?? parseDate(toDateInput.value) ?? today;
                const to = parseDate(toDateInput.value) ?? parseDate(fromDateInput.value) ?? today;
                from.setDate(from.getDate() + days);
                to.setDate(to.getDate() + days);
                fromDateInput.value = formatDate(from);
                toDateInput.value = formatDate(to);
                form.requestSubmit();
            }

            document.getElementById('prevRangeBtn')?.addEventListener('click', () => shiftRange(-1));
            document.getElementById('nextRangeBtn')?.addEventListener('click', () => shiftRange(1));
            document.getElementById('todayFiltersBtn')?.addEventListener('click', function () {
                const today = formatDate(new Date());
                fromDateInput.value = today;
                toDateInput.value = today;
                form.requestSubmit();
            });
        })();
    </script>
}
