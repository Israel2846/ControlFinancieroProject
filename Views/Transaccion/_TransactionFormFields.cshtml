@model ControlFinancieroProject.Models.TransactionFormViewModel

<div class="row g-3">
    <div class="col-12 col-md-6">
        <label asp-for="Fecha" class="form-label">Fecha</label>
        <input asp-for="Fecha" class="form-control" type="date" />
        <span asp-validation-for="Fecha" class="text-danger"></span>
    </div>

    <div class="col-12 col-md-6">
        <label asp-for="Monto" class="form-label">Monto</label>
        <input asp-for="Monto" class="form-control" step="0.01" inputmode="decimal" />
        <span asp-validation-for="Monto" class="text-danger"></span>
    </div>

    <div class="col-12">
        <label asp-for="Descripcion" class="form-label">Descripción</label>
        <textarea asp-for="Descripcion" class="form-control" rows="3" maxlength="500"></textarea>
        <div class="form-text">Máx. 500 caracteres.</div>
        <span asp-validation-for="Descripcion" class="text-danger"></span>
    </div>

    <div class="col-12 col-md-6">
        <label asp-for="SelectedTipo" class="form-label">Tipo</label>
        <select asp-for="SelectedTipo" id="TipoSelect" class="form-select" aria-label="Tipo de transacción">
            <option value="">-- Selecciona tipo --</option>
            @foreach (var tipo in Enum.GetValues<TipoCategoria>())
            {
                <option value="@tipo">@tipo</option>
            }
        </select>
    </div>

    <div class="col-12 col-md-6">
        <label asp-for="CategoriaId" class="form-label">Categoría</label>
        <select asp-for="CategoriaId" id="CategoriaId" class="form-select">
            <option value="">-- Selecciona categoría --</option>
            @foreach (var categoria in Model.Categorias)
            {
                <option value="@categoria.Id" data-tipo="@categoria.Tipo">@categoria.Descripcion</option>
            }
        </select>
        <span asp-validation-for="CategoriaId" class="text-danger"></span>
    </div>

    <div class="col-12 d-flex align-items-end justify-content-end gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary d-inline-flex align-items-center">
            <i class="bi bi-arrow-left me-1" aria-hidden="true"></i>Volver
        </a>

        <button type="submit" class="btn btn-primary d-inline-flex align-items-center">
            <i class="bi bi-save me-1" aria-hidden="true"></i>Guardar
        </button>
    </div>
</div>
