@model ControlFinancieroProject.Models.Transaccion

@{
    ViewData["Title"] = "Detalles de Transacción";
}

<h1>@ViewData["Title"]</h1>

<div>
    <dl class="row">
        <dt class="col-sm-3">Fecha</dt>
        <dd class="col-sm-9">@Model.Fecha.ToString("yyyy-MM-dd")</dd>

        <dt class="col-sm-3">Monto</dt>
        <dd class="col-sm-9">@Model.Monto.ToString("N2")</dd>

        <dt class="col-sm-3">Descripción</dt>
        <dd class="col-sm-9">@Model.Descripcion</dd>

        <dt class="col-sm-3">Saldo Anterior</dt>
        <dd class="col-sm-9">@Model.SaldoAnterior.ToString("N2")</dd>

        <dt class="col-sm-3">Saldo Nuevo</dt>
        <dd class="col-sm-9">@Model.SaldoNuevo.ToString("N2")</dd>

        <dt class="col-sm-3">Categoría</dt>
        <dd class="col-sm-9">@Model.Categoria?.Descripcion</dd>
    </dl>
</div>

<p>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</p>