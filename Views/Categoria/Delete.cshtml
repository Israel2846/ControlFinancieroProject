@model ControlFinancieroProject.Models.Categoria
@using ControlFinancieroProject.Models

@{
    ViewData["Title"] = "Eliminar categoría";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Categorías</a></li>
        <li class="breadcrumb-item active" aria-current="page">Eliminar</li>
    </ol>
</nav>

<div class="card border-warning shadow-sm">
    <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center">
            <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
            <strong>Confirmar eliminación</strong>
        </div>
        <small class="text-muted">Id: @Model.Id</small>
    </div>

    <div class="card-body">
        <p class="mb-3">żDeseas eliminar la categoría <strong class="text-danger">@Model.Descripcion</strong>?</p>

        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <h6 class="text-uppercase text-muted small mb-1">Descripción</h6>
                <p class="mb-0">@Model.Descripcion</p>
            </div>

            <div class="col-md-3">
                <h6 class="text-uppercase text-muted small mb-1">Tipo</h6>
                @if (Model.Tipo == TipoCategoria.Ingreso)
                {
                    <span class="badge rounded-pill bg-success">Ingreso</span>
                }
                else
                {
                    <span class="badge rounded-pill bg-danger">Gasto</span>
                }
            </div>

            <div class="col-md-3">
                <h6 class="text-uppercase text-muted small mb-1">Relación</h6>
                <p class="mb-0 text-muted">Transacciones: <span class="fw-semibold">@(Model.Transacciones?.Count ?? 0)</span></p>
            </div>
        </div>

        <div class="alert alert-warning small">
            Esta acción eliminará la categoría permanentemente. Si la categoría está asociada a transacciones, revisa antes sus registros.
        </div>

        <form asp-action="Delete" method="post" class="d-flex gap-2">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn btn-danger d-inline-flex align-items-center">
                <i class="bi bi-trash me-1" aria-hidden="true"></i>Eliminar
            </button>

            <a asp-action="Index" class="btn btn-outline-secondary d-inline-flex align-items-center">
                <i class="bi bi-arrow-left me-1" aria-hidden="true"></i>Cancelar
            </a>
        </form>
    </div>
</div>