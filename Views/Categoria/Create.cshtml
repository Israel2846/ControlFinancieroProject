@model ControlFinancieroProject.Models.Categoria
@using ControlFinancieroProject.Models

@{
    ViewData["Title"] = "Crear categoría";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Categorías</a></li>
        <li class="breadcrumb-item active" aria-current="page">Crear</li>
    </ol>
</nav>

<div class="card shadow-sm">
    <div class="card-body">
        <h4 class="card-title mb-3"><i class="bi bi-folder-plus me-2" aria-hidden="true"></i>Crear categoría</h4>

        <form asp-action="Create" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert"></div>

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Descripcion" class="form-label">Nombre</label>
                    <input asp-for="Descripcion" class="form-control" maxlength="100" placeholder="Ej. Salario, Comida, Transporte" autofocus />
                    <div class="form-text">Máx. 100 caracteres.</div>
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>

                <div class="col-sm-6">
                    <label asp-for="Tipo" class="form-label">Tipo</label>
                    <select asp-for="Tipo" asp-items="Html.GetEnumSelectList<ControlFinancieroProject.Models.TipoCategoria>()" class="form-select">
                        <option value="">-- Selecciona tipo --</option>
                    </select>
                    <span asp-validation-for="Tipo" class="text-danger"></span>
                </div>

                <div class="col-sm-6 d-flex align-items-end justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-outline-secondary d-inline-flex align-items-center">
                        <i class="bi bi-arrow-left me-1" aria-hidden="true"></i><span class="d-none d-sm-inline">Volver</span>
                    </a>

                    <button type="submit" class="btn btn-primary d-inline-flex align-items-center">
                        <i class="bi bi-save me-1" aria-hidden="true"></i>Guardar
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Mostrar summary de validación si hay errores (mejora UX)
        (function () {
            const form = document.querySelector('form[asp-action="Create"]');
            if (!form) return;

            form.addEventListener('submit', function () {
                // small delay to let unobtrusive validation run
                setTimeout(() => {
                    const summary = document.querySelector('div[asp-validation-summary="ModelOnly"]');
                    const errors = document.querySelectorAll('.text-danger:visible, .input-validation-error');
                    if (summary) {
                        if (errors.length > 0) {
                            summary.classList.remove('d-none');
                            summary.textContent = 'Corrige los errores en el formulario antes de continuar.';
                        } else {
                            summary.classList.add('d-none');
                        }
                    }
                }, 10);
            }, { passive: true });
        })();
    </script>
}