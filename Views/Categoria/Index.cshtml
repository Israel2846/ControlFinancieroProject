@model IEnumerable<ControlFinancieroProject.Models.Categoria>
@using ControlFinancieroProject.Models

@{
    ViewData["Title"] = "Categorías";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 text-dark mb-0">@ViewData["Title"]</h1>

    <div class="d-flex gap-2 align-items-center">
        <input id="searchInput" class="form-control form-control-sm" style="min-width:220px" placeholder="Buscar categorías..." aria-label="Buscar categorías" />
        <a asp-action="Create" class="btn btn-sm btn-primary d-inline-flex align-items-center">
            <i class="bi bi-plus-lg me-1" aria-hidden="true"></i> Nueva
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-folder2-open fs-3 mb-2" aria-hidden="true"></i>
            <div class="fw-semibold">Aún no hay categorías</div>
            <div class="small">Crea tu primera categoría para empezar a clasificar transacciones.</div>
            <div class="mt-3">
                <a asp-action="Create" class="btn btn-sm btn-outline-primary">Crear categoría</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var categoria in Model)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-start justify-content-between mb-2">
                            <div>
                                <h5 class="card-title mb-1 text-truncate" style="max-width:220px">@categoria.Descripcion</h5>
                                <div class="text-muted small">ID: @categoria.Id</div>
                            </div>

                            <div class="text-end ms-2">
                                @if (categoria.Tipo == TipoCategoria.Ingreso)
                                {
                                    <span class="badge border border-success text-success rounded-pill" style="background-color: rgba(25,135,84,0.06);">
                                        <i class="bi bi-arrow-up-short me-1"></i>Ingreso
                                    </span>
                                }
                                else
                                {
                                    <span class="badge border border-danger text-danger rounded-pill" style="background-color: rgba(220,53,69,0.06);">
                                        <i class="bi bi-arrow-down-short me-1"></i>Gasto
                                    </span>
                                }
                            </div>
                        </div>

                        <p class="card-text text-muted small mb-3">@((string.IsNullOrWhiteSpace(categoria.Descripcion) ? "-" : categoria.Descripcion))</p>

                        <div class="mt-auto d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@categoria.Id" class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center">
                                <i class="bi bi-eye me-1"></i><span class="d-none d-sm-inline">Ver</span>
                            </a>
                            <a asp-action="Edit" asp-route-id="@categoria.Id" class="btn btn-sm btn-outline-warning d-inline-flex align-items-center">
                                <i class="bi bi-pencil me-1"></i><span class="d-none d-sm-inline">Editar</span>
                            </a>
                            <a asp-action="Delete" asp-route-id="@categoria.Id" class="btn btn-sm btn-outline-danger d-inline-flex align-items-center">
                                <i class="bi bi-trash me-1"></i><span class="d-none d-sm-inline">Eliminar</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        (function () {
            const input = document.getElementById('searchInput');
            if (!input) return;

            let timer;
            input.addEventListener('input', function () {
                clearTimeout(timer);
                const q = this.value.trim().toLowerCase();
                timer = setTimeout(() => {
                    document.querySelectorAll('.card.h-100').forEach(function (card) {
                        const text = card.innerText.toLowerCase();
                        card.parentElement.style.display = q === '' || text.indexOf(q) !== -1 ? '' : 'none';
                    });
                }, 200);
            });
        })();
    </script>
}
