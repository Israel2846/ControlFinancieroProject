@model ControlFinancieroProject.Models.Categoria
@using ControlFinancieroProject.Models

@{
    ViewData["Title"] = "Editar categoría";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Categorías</a></li>
        <li class="breadcrumb-item active" aria-current="page">Editar</li>
    </ol>
</nav>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h4 class="card-title mb-0"><i class="bi bi-pencil-square me-2" aria-hidden="true"></i>Editar categoría</h4>
                <small class="text-muted">Id: <span class="fw-semibold">@Model.Id</span></small>
            </div>
            <div class="btn-group" role="group" aria-label="Acciones">
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center">
                    <i class="bi bi-arrow-left me-1" aria-hidden="true"></i><span class="d-none d-sm-inline">Volver</span>
                </a>
            </div>
        </div>

        <hr />

        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" novalidate>
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" role="alert"></div>

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Descripcion" class="form-label">Nombre</label>
                    <input asp-for="Descripcion" class="form-control" maxlength="100" placeholder="Ej. Salario, Comida, Transporte" autofocus />
                    <div class="form-text">Máx. 100 caracteres.</div>
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>

                <div class="col-sm-6">
                    <label asp-for="Tipo" class="form-label">Tipo</label>
                    <select asp-for="Tipo" asp-items="Html.GetEnumSelectList<TipoCategoria>()" class="form-select">
                        <option value="">-- Selecciona tipo --</option>
                    </select>
                    <span asp-validation-for="Tipo" class="text-danger"></span>
                </div>

                <div class="col-sm-6 d-flex align-items-end justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary d-inline-flex align-items-center">
                        <i class="bi bi-save me-1" aria-hidden="true"></i>Guardar
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary d-inline-flex align-items-center">
                        <i class="bi bi-x-circle me-1" aria-hidden="true"></i>Cancelar
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            // Mostrar resumen si hay errores tras validación unobtrusive
            const form = document.querySelector('form[asp-action="Edit"]');
            const summary = document.querySelector('div[asp-validation-summary="ModelOnly"]');
            if (!form || !summary) return;

            form.addEventListener('submit', function () {
                setTimeout(() => {
                    const errors = document.querySelectorAll('.input-validation-error, .validation-summary-errors li');
                    if (errors.length > 0) {
                        summary.classList.remove('d-none');
                        summary.textContent = 'Corrige los errores antes de continuar.';
                    } else {
                        summary.classList.add('d-none');
                    }
                }, 10);
            }, { passive: true });
        })();
    </script>
}