@{
    ViewData["Title"] = "Inicio - ControlFinanciero";
    var now = DateTime.Now;
    var year = now.Year;
    var month = now.Month;
}
<div class="py-5 text-dark">
    <div class="container">
        <div class="row align-items-center gy-4">
            <div class="col-lg-7">
                <h1 class="display-5 fw-bold">ControlFinanciero</h1>
                <p class="lead text-muted">Gestiona tus categorías y transacciones de forma simple y segura. Visualiza, crea y administra tus registros financieros rápidamente.</p>

                <div class="d-flex flex-wrap gap-2 mt-3">
                    <a asp-controller="Categoria" asp-action="Index" class="btn btn-primary btn-lg d-inline-flex align-items-center">
                        <i class="bi bi-tags me-2" aria-hidden="true"></i> Categorías
                    </a>

                    <!-- Resumen del mes: acceso directo al reporte mensual -->
                    <a asp-controller="Transaccion" asp-action="MonthlyReport" asp-route-year="@year" asp-route-month="@month"
                       class="btn btn-outline-primary btn-lg d-inline-flex align-items-center">
                        <i class="bi bi-calendar2-event me-2" aria-hidden="true"></i> Resumen del mes
                    </a>

                    <a asp-controller="Categoria" asp-action="Create" class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center align-self-center">
                        <i class="bi bi-plus-lg me-1" aria-hidden="true"></i> Nueva categoría
                    </a>
                </div>

                <p class="text-muted small mt-3 mb-0">Consejo: usa los enlaces de arriba para acceder rápidamente a informes y a la gestión de categorías.</p>
            </div>

            <div class="col-lg-5">
                <div class="row g-3">
                    <div class="col-12">
                        <div class="card shadow-sm h-100">
                            <div class="card-body">
                                <h6 class="mb-1">Resumen rápido (acceso)</h6>
                                <div class="d-flex gap-3 align-items-center">
                                    <div class="small text-muted">Mes</div>
                                    <div class="fw-semibold">@now.ToString("MMMM yyyy")</div>
                                </div>

                                <div class="mt-3 d-flex gap-2">
                                    <a asp-controller="Transaccion" asp-action="MonthlyReport" asp-route-year="@year" asp-route-month="@month" class="btn btn-sm btn-outline-primary">
                                        Ver reporte
                                    </a>
                                    <a asp-controller="Transaccion" asp-action="Comparative" class="btn btn-sm btn-outline-secondary">
                                        Comparativo
                                    </a>
                                </div>

                                <div class="mt-3 small text-muted">
                                    Aquí tienes accesos directos a los informes principales. Para datos detallados abre el reporte mensual.
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-body">
                                <div class="d-flex align-items-center">
                                    <div class="me-3 display-6 text-primary"><i class="bi bi-tags"></i></div>
                                    <div>
                                        <h6 class="mb-0">Categorías</h6>
                                        <small class="text-muted">Administrar tipos</small>
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <a asp-controller="Categoria" asp-action="Index" class="stretched-link text-decoration-none">Ver todas →</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="card shadow-sm h-100">
                            <div class="card-body">
                                <div class="d-flex align-items-center">
                                    <div class="me-3 display-6 text-success"><i class="bi bi-list-check"></i></div>
                                    <div>
                                        <h6 class="mb-0">Transacciones</h6>
                                        <small class="text-muted">Ingresos y gastos</small>
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <a asp-controller="Transaccion" asp-action="Index" class="stretched-link text-decoration-none">Ver todas →</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="card border-0 bg-light small">
                            <div class="card-body">
                                <strong>Atajos rápidos</strong>
                                <ul class="mb-0">
                                    <li>Crear una nueva categoría: <a asp-controller="Categoria" asp-action="Create">Nueva categoría</a></li>
                                    <li>Ir al resumen mensual: <a asp-controller="Transaccion" asp-action="MonthlyReport" asp-route-year="@year" asp-route-month="@month">Resumen del mes</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div><!-- row -->
    </div><!-- container -->
</div>
